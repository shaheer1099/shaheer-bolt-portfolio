{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/portfolio-icon.png",
      "dest": "/public/portfolio-icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
