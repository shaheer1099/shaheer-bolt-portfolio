PORT=5000
NODE_ENV=development

# Comma-separated allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional comma-separated URLs the browser may connect to from pages served by this backend.
# Add the deployed contact API origin here if the frontend calls an absolute URL.
CSP_CONNECT_SOURCES=

# Optional shared token. If set, frontend must send it as x-contact-token.
CONTACT_ROUTE_TOKEN=

# Gmail SMTP. Use a Google app password, not the normal account password.
# Option A: SMTP_PORT=465 and SMTP_SECURE=true
# Option B: SMTP_PORT=587 and SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-google-email@gmail.com
SMTP_PASS=your-google-app-password

CONTACT_TO_EMAIL=shaheerasheikh00@gmail.com
CONTACT_FROM_EMAIL=your-google-email@gmail.com
